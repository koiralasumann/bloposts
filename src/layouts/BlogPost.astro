---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, tags } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${title} — Suman Koirala`} description={description} />
	</head>
	<body>
		<Header />
		<main class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
			<article>
				<header class="mb-8">
					<div class="flex items-center gap-3 text-sm text-text-muted dark:text-dark-text-muted mb-3">
						<FormattedDate date={pubDate} />
						{updatedDate && (
							<span class="italic">
								(updated <FormattedDate date={updatedDate} />)
							</span>
						)}
					</div>
					<h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-text dark:text-dark-text leading-tight">
						{title}
					</h1>
					{tags && tags.length > 0 && (
						<div class="flex flex-wrap gap-2 mt-4">
							{tags.map((tag: string) => (
								<span class="text-xs font-mono px-2 py-1 rounded bg-surface-alt dark:bg-dark-surface-alt text-text-muted dark:text-dark-text-muted border border-border dark:border-dark-border">
									{tag}
								</span>
							))}
						</div>
					)}
					<hr class="mt-6 border-border dark:border-dark-border" />
				</header>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
