---
import { SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname;

const navLinks = [
	{ href: `${base}`, label: 'Home' },
	{ href: `${base}about/`, label: 'About' },
	{ href: `${base}portfolio/`, label: 'Portfolio' },
	{ href: `${base}blog/`, label: 'Blog' },
	{ href: `${base}contact/`, label: 'Contact' },
];
---

<header class="sticky top-0 z-50 border-b border-border dark:border-dark-border bg-surface/80 dark:bg-dark-surface/80 backdrop-blur-md">
	<nav class="max-w-4xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
		<a href={base} class="text-lg font-semibold text-text dark:text-dark-text hover:text-accent transition-colors">
			{SITE_TITLE}
		</a>

		<!-- Desktop nav -->
		<div class="hidden md:flex items-center gap-1">
			{navLinks.map(({ href, label }) => {
				const isActive = href === '/'
					? pathname === '/'
					: pathname.startsWith(href);
				return (
					<a
						href={href}
						class:list={[
							'px-3 py-1.5 rounded-md text-sm transition-colors',
							isActive
								? 'text-accent font-medium'
								: 'text-text-muted dark:text-dark-text-muted hover:text-text dark:hover:text-dark-text',
						]}
					>
						{label}
					</a>
				);
			})}
			<button
				id="theme-toggle"
				aria-label="Toggle dark mode"
				class="ml-2 p-2 rounded-md text-text-muted dark:text-dark-text-muted hover:text-text dark:hover:text-dark-text hover:bg-surface-alt dark:hover:bg-dark-surface-alt transition-colors"
			>
				<svg class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
				</svg>
				<svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
				</svg>
			</button>
		</div>

		<!-- Mobile menu button -->
		<div class="flex items-center gap-2 md:hidden">
			<button
				id="theme-toggle-mobile"
				aria-label="Toggle dark mode"
				class="p-2 rounded-md text-text-muted dark:text-dark-text-muted hover:text-text dark:hover:text-dark-text transition-colors"
			>
				<svg class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
				</svg>
				<svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
				</svg>
			</button>
			<button
				id="mobile-menu-btn"
				aria-label="Open menu"
				class="p-2 rounded-md text-text-muted dark:text-dark-text-muted hover:text-text dark:hover:text-dark-text transition-colors"
			>
				<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
				</svg>
			</button>
		</div>
	</nav>

	<!-- Mobile nav panel -->
	<div id="mobile-menu" class="hidden md:hidden border-t border-border dark:border-dark-border bg-surface dark:bg-dark-surface">
		<div class="px-4 py-3 space-y-1">
			{navLinks.map(({ href, label }) => {
				const isActive = href === '/'
					? pathname === '/'
					: pathname.startsWith(href);
				return (
					<a
						href={href}
						class:list={[
							'block px-3 py-2 rounded-md text-sm transition-colors',
							isActive
								? 'text-accent font-medium bg-surface-alt dark:bg-dark-surface-alt'
								: 'text-text-muted dark:text-dark-text-muted hover:text-text dark:hover:text-dark-text hover:bg-surface-alt dark:hover:bg-dark-surface-alt',
						]}
					>
						{label}
					</a>
				);
			})}
		</div>
	</div>
</header>

<script>
	function setupThemeToggle() {
		const toggleTheme = () => {
			const isDark = document.documentElement.classList.toggle('dark');
			localStorage.setItem('theme', isDark ? 'dark' : 'light');
		};

		document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
		document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);

		document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
			const menu = document.getElementById('mobile-menu');
			menu?.classList.toggle('hidden');
		});
	}

	setupThemeToggle();
	document.addEventListener('astro:after-swap', setupThemeToggle);
</script>
